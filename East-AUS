<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>2024-25 東澳跨年旅 🇦🇺</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
    
    <!-- Custom CSS -->
    <style>
        /* Glassmorphism Utilities */
        .glass {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(226, 232, 240, 0.8);
        }
        .glass-dark {
            background: rgba(15, 23, 42, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
        
        /* Smooth Scrolling */
        html { scroll-behavior: smooth; }
        
        /* Hide Scrollbar but keep functionality */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* Timeline specific */
        .timeline-container::before {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            left: 24px;
            width: 2px;
            background-color: #cbd5e1; /* slate-300 */
        }
        
        /* Detail Mode Toggle */
        .compact-mode .detail-block { display: none !important; }
        
        /* Custom Checkbox */
        .custom-checkbox:checked + div { background-color: #3b82f6; border-color: #3b82f6; }
        .custom-checkbox:checked + div svg { display: block; }
        
        /* Leaflet Map Height */
        #map { height: 400px; z-index: 10; border-radius: 0.75rem;}
        .leaflet-popup-content-wrapper { border-radius: 0.5rem; }
        
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 transition-all duration-300">

    <!-- Top Navigation -->
    <nav class="fixed top-0 w-full z-50 glass transition-all duration-300" id="top-nav">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <!-- Logo / Title -->
                <div class="flex-shrink-0 flex items-center gap-2 cursor-pointer" onclick="switchView('dashboard')">
                    <span class="text-2xl">🦘</span>
                    <span class="font-bold text-lg tracking-tight text-slate-800">東澳跨年特攻隊</span>
                </div>
                
                <!-- Desktop Menu -->
                <div class="hidden md:flex space-x-1">
                    <button onclick="switchView('dashboard')" class="nav-btn px-3 py-2 rounded-md text-sm font-medium text-blue-600 bg-blue-50 transition-colors" data-target="dashboard">📊 儀表盤</button>
                    <button onclick="switchView('itinerary')" class="nav-btn px-3 py-2 rounded-md text-sm font-medium text-slate-600 hover:bg-slate-100 transition-colors" data-target="itinerary">📅 行程細節</button>
                    <button onclick="switchView('food')" class="nav-btn px-3 py-2 rounded-md text-sm font-medium text-slate-600 hover:bg-slate-100 transition-colors" data-target="food">🍔 美食地圖</button>
                    <button onclick="switchView('tools')" class="nav-btn px-3 py-2 rounded-md text-sm font-medium text-slate-600 hover:bg-slate-100 transition-colors" data-target="tools">🧮 實用工具</button>
                    <button onclick="switchView('info')" class="nav-btn px-3 py-2 rounded-md text-sm font-medium text-slate-600 hover:bg-slate-100 transition-colors" data-target="info">ℹ️ 準備與資訊</button>
                </div>
                
                <!-- Mobile Menu Button -->
                <div class="md:hidden flex items-center">
                    <button id="mobile-menu-btn" class="text-slate-600 hover:text-slate-900 focus:outline-none p-2">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Mobile Menu (Hidden by default) -->
        <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200 bg-white shadow-lg absolute w-full z-40">
            <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
                <button onclick="switchView('dashboard')" class="nav-btn block w-full text-left px-3 py-2 rounded-md text-base font-medium text-blue-600 bg-blue-50" data-target="dashboard">📊 行程儀表盤</button>
                <button onclick="switchView('itinerary')" class="nav-btn block w-full text-left px-3 py-2 rounded-md text-base font-medium text-slate-600 hover:bg-slate-50" data-target="itinerary">📅 每日行程細節</button>
                <button onclick="switchView('food')" class="nav-btn block w-full text-left px-3 py-2 rounded-md text-base font-medium text-slate-600 hover:bg-slate-50" data-target="food">🍔 美食地圖</button>
                <button onclick="switchView('tools')" class="nav-btn block w-full text-left px-3 py-2 rounded-md text-base font-medium text-slate-600 hover:bg-slate-50" data-target="tools">🧮 實用工具</button>
                <button onclick="switchView('info')" class="nav-btn block w-full text-left px-3 py-2 rounded-md text-base font-medium text-slate-600 hover:bg-slate-50" data-target="info">ℹ️ 準備與資訊</button>
            </div>
        </div>
    </nav>

    <!-- Main Content Area -->
    <main class="pt-24 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto min-h-screen">
        
        <!-- ================= VIEW 1: Dashboard ================= -->
        <section id="view-dashboard" class="space-y-6 animate-fade-in pb-10">
            <!-- Hero Banner -->
            <div class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-2xl p-6 sm:p-10 text-white shadow-lg relative overflow-hidden">
                <div class="relative z-10">
                    <span class="inline-block px-3 py-1 bg-white/20 rounded-full text-sm font-semibold tracking-wider mb-3 backdrop-blur-sm">2024.12.25 - 2025.01.05</span>
                    <h1 class="text-3xl sm:text-5xl font-extrabold mb-4">墨爾本 ✈️ 雪梨跨年行</h1>
                    <div class="flex flex-wrap gap-4 text-blue-100">
                        <div class="flex items-center gap-2"><span class="text-xl">🧑‍🤝‍🧑</span> 4 人同行</div>
                        <div class="flex items-center gap-2"><span class="text-xl">🚌</span> 輕鬆 One Day Tour + 國內線</div>
                        <div class="flex items-center gap-2"><span class="text-xl">⛴️</span> 郵輪海上賞煙火</div>
                    </div>
                </div>
                <!-- Decorative SVG -->
                <svg class="absolute -bottom-10 -right-10 opacity-20 w-64 h-64" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            </div>

            <!-- Weather Forecast (Mock) -->
            <div class="bg-white rounded-2xl shadow-sm p-5 border border-slate-200">
                <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">🌤️ 天氣預測 (示意)</h3>
                <div class="flex overflow-x-auto gap-4 pb-2 no-scrollbar">
                    <!-- Dynamic weather generated by JS -->
                    <div id="weather-container" class="flex gap-3"></div>
                </div>
            </div>

            <!-- Map & Chart Grid -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- Interactive Map -->
                <div class="bg-white rounded-2xl shadow-sm p-1 border border-slate-200 relative">
                    <div id="map"></div>
                </div>
                
                <!-- Chart & Highlights -->
                <div class="space-y-6">
                    <div class="bg-white rounded-2xl shadow-sm p-5 border border-slate-200">
                        <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">📊 體力分析 (交通 vs 遊玩)</h3>
                        <!-- CHART WRAPPER: Fixed height absolutely prevents infinite resize bug -->
                        <div class="relative w-full h-[250px]">
                            <canvas id="intensityChart"></canvas>
                        </div>
                    </div>
                    
                    <div class="bg-white rounded-2xl shadow-sm p-5 border border-slate-200">
                        <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">✨ 行程亮點快搜</h3>
                        <div class="grid grid-cols-2 gap-3">
                            <button onclick="jumpToDay(2)" class="text-left p-3 rounded-xl bg-slate-50 hover:bg-blue-50 transition border border-slate-100 group">
                                <div class="text-sm text-slate-500 mb-1">Day 2</div>
                                <div class="font-bold text-slate-800 group-hover:text-blue-700">🌊 大洋路絕景</div>
                            </button>
                            <button onclick="jumpToDay(4)" class="text-left p-3 rounded-xl bg-slate-50 hover:bg-blue-50 transition border border-slate-100 group">
                                <div class="text-sm text-slate-500 mb-1">Day 4</div>
                                <div class="font-bold text-slate-800 group-hover:text-blue-700">🐧 企鵝歸巢</div>
                            </button>
                            <button onclick="jumpToDay(7)" class="text-left p-3 rounded-xl bg-slate-50 hover:bg-blue-50 transition border border-slate-100 group">
                                <div class="text-sm text-slate-500 mb-1">Day 7</div>
                                <div class="font-bold text-slate-800 group-hover:text-blue-700">⛴️ 郵輪跨年煙火</div>
                            </button>
                            <button onclick="jumpToDay(8)" class="text-left p-3 rounded-xl bg-slate-50 hover:bg-blue-50 transition border border-slate-100 group">
                                <div class="text-sm text-slate-500 mb-1">Day 8</div>
                                <div class="font-bold text-slate-800 group-hover:text-blue-700">⛰️ 藍山一日遊</div>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ================= VIEW 2: Daily Itinerary ================= -->
        <section id="view-itinerary" class="hidden animate-fade-in pb-10">
            <div class="mb-6 flex justify-between items-end">
                <div>
                    <h2 class="text-2xl font-bold text-slate-800">📅 完整行程表</h2>
                    <p class="text-slate-500 text-sm mt-1">往下滑動查看每日細節，或使用下方快捷鍵跳轉。</p>
                </div>
            </div>
            
            <!-- Itinerary Container (Generated by JS) -->
            <div id="itinerary-container" class="space-y-12"></div>
        </section>

        <!-- ================= VIEW 3: Food Map ================= -->
        <section id="view-food" class="hidden animate-fade-in pb-10">
            <h2 class="text-2xl font-bold text-slate-800 mb-4">🍔 美食口袋名單</h2>
            
            <!-- Filters -->
            <div class="flex flex-wrap gap-2 mb-6" id="food-filters">
                <button class="px-4 py-2 rounded-full bg-slate-800 text-white text-sm font-medium transition filter-btn shadow-sm" data-filter="all">全部</button>
                <button class="px-4 py-2 rounded-full bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 text-sm font-medium transition filter-btn shadow-sm" data-filter="seafood">🦞 海鮮大餐</button>
                <button class="px-4 py-2 rounded-full bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 text-sm font-medium transition filter-btn shadow-sm" data-filter="brunch">🍳 早午餐</button>
                <button class="px-4 py-2 rounded-full bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 text-sm font-medium transition filter-btn shadow-sm" data-filter="asian">🍜 亞洲風味</button>
                <button class="px-4 py-2 rounded-full bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 text-sm font-medium transition filter-btn shadow-sm" data-filter="snack">🍦 小吃甜點</button>
            </div>
            
            <!-- Food Grid (Generated by JS) -->
            <div id="food-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
        </section>

        <!-- ================= VIEW 4: Tools ================= -->
        <section id="view-tools" class="hidden animate-fade-in pb-10">
            <h2 class="text-2xl font-bold text-slate-800 mb-6">🧮 實用工具</h2>
            
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- Currency Converter -->
                <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-200">
                    <div class="flex items-center gap-3 mb-5">
                        <span class="text-2xl p-2 bg-blue-50 rounded-xl">💱</span>
                        <h3 class="text-xl font-bold">匯率換算器</h3>
                    </div>
                    
                    <div class="space-y-4">
                        <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
                            <span class="text-sm font-medium text-slate-600">自訂匯率 (AUD to TWD)</span>
                            <input type="number" id="custom-rate" value="21.5" step="0.1" class="w-24 px-3 py-1 border border-slate-300 rounded text-right focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 bg-white">
                        </div>
                        
                        <div class="relative">
                            <div class="flex flex-col gap-4">
                                <div class="flex items-center border border-slate-200 rounded-xl overflow-hidden focus-within:ring-2 focus-within:ring-blue-500 bg-white">
                                    <div class="bg-slate-100 px-4 py-3 font-bold text-slate-600 w-24 text-center border-r border-slate-200">🇦🇺 AUD</div>
                                    <input type="number" id="aud-input" class="flex-1 px-4 py-3 text-lg focus:outline-none" placeholder="輸入澳幣">
                                </div>
                                
                                <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-white rounded-full p-1 border border-slate-200 shadow-sm z-10">
                                    <svg class="w-6 h-6 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path></svg>
                                </div>
                                
                                <div class="flex items-center border border-slate-200 rounded-xl overflow-hidden focus-within:ring-2 focus-within:ring-blue-500 bg-white">
                                    <div class="bg-slate-100 px-4 py-3 font-bold text-slate-600 w-24 text-center border-r border-slate-200">🇹🇼 TWD</div>
                                    <input type="number" id="twd-input" class="flex-1 px-4 py-3 text-lg focus:outline-none" placeholder="輸入台幣">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Expense Tracker -->
                <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-200 flex flex-col h-[500px]">
                    <div class="flex items-center gap-3 mb-5">
                        <span class="text-2xl p-2 bg-green-50 rounded-xl">💸</span>
                        <h3 class="text-xl font-bold">公積金記帳本</h3>
                    </div>
                    
                    <form id="expense-form" class="flex gap-2 mb-4">
                        <input type="text" id="expense-name" required placeholder="項目 (如: 晚餐)" class="flex-1 px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 bg-white">
                        <input type="number" id="expense-amount" required placeholder="AUD" step="0.01" class="w-24 px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 bg-white">
                        <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg font-medium transition shadow-sm">新增</button>
                    </form>
                    
                    <div class="flex-1 overflow-y-auto mb-4 border border-slate-100 rounded-lg bg-slate-50 p-2 shadow-inner">
                        <ul id="expense-list" class="space-y-2">
                            <!-- Items via JS -->
                            <li class="text-center text-slate-400 py-4 text-sm">尚無紀錄，開始新增吧！</li>
                        </ul>
                    </div>
                    
                    <div class="bg-slate-800 text-white p-4 rounded-xl shadow-md">
                        <div class="flex justify-between items-center mb-1">
                            <span class="text-slate-300">總計 (AUD)</span>
                            <span class="text-2xl font-bold" id="total-aud">$0.00</span>
                        </div>
                        <div class="flex justify-between items-center text-sm">
                            <span class="text-slate-400">約合台幣 (TWD)</span>
                            <span class="text-green-400 font-medium" id="total-twd">NT$0</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ================= VIEW 5: Info & Prep ================= -->
        <section id="view-info" class="hidden animate-fade-in space-y-8 pb-10">
            <h2 class="text-2xl font-bold text-slate-800">ℹ️ 準備與重要資訊</h2>
            
            <!-- Flight Info -->
            <div class="bg-white rounded-2xl shadow-sm overflow-hidden border border-slate-200">
                <div class="bg-indigo-50 px-6 py-4 border-b border-indigo-100 flex items-center gap-2">
                    <span class="text-xl">✈️</span> <h3 class="font-bold text-indigo-900">關鍵航班資訊</h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 text-slate-500 text-sm">
                                <th class="py-3 px-6 font-medium">日期</th>
                                <th class="py-3 px-6 font-medium">航段</th>
                                <th class="py-3 px-6 font-medium">航班號碼</th>
                                <th class="py-3 px-6 font-medium">時間</th>
                                <th class="py-3 px-6 font-medium text-center">動態追蹤</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            <tr>
                                <td class="py-3 px-6">12/25</td>
                                <td class="py-3 px-6">台北 (TPE) ➔ 墨爾本 (MEL)</td>
                                <td class="py-3 px-6 font-mono font-bold text-slate-700">酷航 TR899/TGW899</td>
                                <td class="py-3 px-6">01:30 - 12:15</td>
                                <td class="py-3 px-6 text-center">
                                    <a href="https://zh-tw.flightaware.com/live/flight/TGW899" target="_blank" class="inline-flex items-center justify-center p-2 bg-blue-100 text-blue-700 rounded-full hover:bg-blue-200 transition shadow-sm">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                                    </a>
                                </td>
                            </tr>
                            <tr>
                                <td class="py-3 px-6">12/30</td>
                                <td class="py-3 px-6">墨爾本 (MEL) ➔ 雪梨 (SYD)</td>
                                <td class="py-3 px-6 font-mono font-bold text-slate-700">捷星 JQ506</td>
                                <td class="py-3 px-6">09:20 - 10:45</td>
                                <td class="py-3 px-6 text-center">
                                    <a href="https://zh-tw.flightaware.com/live/flight/JST506" target="_blank" class="inline-flex items-center justify-center p-2 bg-blue-100 text-blue-700 rounded-full hover:bg-blue-200 transition shadow-sm">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                                    </a>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Accommodation -->
                <div class="bg-white rounded-2xl shadow-sm p-6 border border-slate-200">
                    <h3 class="text-lg font-bold mb-4 flex items-center gap-2 text-slate-800">🏨 住宿安排</h3>
                    <div class="space-y-4">
                        <div class="p-4 bg-slate-50 rounded-xl border border-slate-200 shadow-sm">
                            <div class="flex justify-between items-start mb-2">
                                <div>
                                    <h4 class="font-bold text-blue-900 text-lg">Aspire Melbourne</h4>
                                    <p class="text-sm text-slate-500 font-medium mt-0.5">12/25 - 12/30 (5晚)</p>
                                </div>
                                <a href="https://maps.google.com/?q=Aspire+Melbourne" target="_blank" class="px-2 py-1 bg-blue-100 text-blue-700 text-xs rounded-md hover:bg-blue-200 transition font-bold">📍 導航</a>
                            </div>
                            <p class="text-sm text-slate-700 mb-1 flex items-center gap-1"><span class="text-slate-400">▪</span> 房型: 雙臥室公寓 (4人)</p>
                            <p class="text-sm text-red-600 font-bold flex items-center gap-1"><span>⚠️</span> Check-in: 15:00 後</p>
                        </div>
                        <div class="p-4 bg-slate-50 rounded-xl border border-slate-200 shadow-sm">
                            <div class="flex justify-between items-start mb-2">
                                <div>
                                    <h4 class="font-bold text-blue-900 text-lg">Adina Apartment Hotel</h4>
                                    <p class="text-sm text-slate-500 font-medium mt-0.5">12/30 - 01/05 (6晚) · Chippendale</p>
                                </div>
                                <a href="https://maps.google.com/?q=Adina+Apartment+Hotel+Sydney+Chippendale" target="_blank" class="px-2 py-1 bg-blue-100 text-blue-700 text-xs rounded-md hover:bg-blue-200 transition font-bold">📍 導航</a>
                            </div>
                            <p class="text-sm text-slate-700 mb-1 flex items-center gap-1"><span class="text-slate-400">▪</span> 房型: 家庭套房 (4人)</p>
                            <p class="text-sm text-red-600 font-bold flex items-center gap-1"><span>⚠️</span> Check-in: 14:00 後</p>
                        </div>
                    </div>
                </div>

                <!-- Day Tour Info -->
                <div class="bg-white rounded-2xl shadow-sm p-6 border border-slate-200">
