        function switchView(viewId) {
            // Hide all sections
            document.querySelectorAll('main > section').forEach(sec => {
                sec.classList.add('hidden');
            });
            // Show target
            document.getElementById(`view-${viewId}`).classList.remove('hidden');
            
            // Update Nav buttons
            document.querySelectorAll('.nav-btn').forEach(btn => {
                if (btn.dataset.target === viewId) {
                    btn.classList.remove('text-slate-600', 'hover:bg-slate-100', 'hover:bg-slate-50');
                    btn.classList.add('text-blue-600', 'bg-blue-50');
                } else {
                    btn.classList.add('text-slate-600');
                    btn.classList.remove('text-blue-600', 'bg-blue-50');
                    if(btn.parentElement.classList.contains('hidden')) {
                        btn.classList.add('hover:bg-slate-50');
                    } else {
                        btn.classList.add('hover:bg-slate-100');
                    }
                }
            });

            // Close mobile menu
            document.getElementById('mobile-menu').classList.add('hidden');
            
            // Control Bottom Panel Visibility (Only show on itinerary)
            const bottomPanel = document.getElementById('bottom-panel');
            if(viewId === 'itinerary') {
                bottomPanel.classList.remove('translate-y-full', 'opacity-0');
                bottomPanel.classList.add('translate-y-0', 'opacity-100');
                document.body.classList.add('pb-16'); // Add padding to body so last item isn't covered
            } else {
                bottomPanel.classList.add('translate-y-full', 'opacity-0');
                bottomPanel.classList.remove('translate-y-0', 'opacity-100');
                document.body.classList.remove('pb-16');
            }

            // Scroll to top smoothly
            window.scrollTo({ top: 0, behavior: 'smooth' });

            // Fix map and chart dimensions when switching back to dashboard
            if (viewId === 'dashboard') {
                if (map) setTimeout(() => map.invalidateSize(), 100);
            }
        }

        function handleScroll() {
            const btn = document.getElementById('back-to-top');
            if (window.scrollY > 300) {
                btn.classList.remove('opacity-0', 'pointer-events-none');
                btn.classList.add('opacity-100', 'pointer-events-auto');
            } else {
                btn.classList.add('opacity-0', 'pointer-events-none');
                btn.classList.remove('opacity-100', 'pointer-events-auto');
            }
        }

