        // ==========================================
        // 7. Tools (Currency & Expense)
        // ==========================================
        let expenses = [];
        
        function initTools() {
            // Currency Converter
            const audInput = document.getElementById('aud-input');
            const twdInput = document.getElementById('twd-input');
            const rateInput = document.getElementById('custom-rate');

            const calculate = (source) => {
                const rate = parseFloat(rateInput.value) || 21.5;
                if (source === 'aud') {
                    const aud = parseFloat(audInput.value);
                    twdInput.value = isNaN(aud) ? '' : Math.round(aud * rate);
                } else if (source === 'twd') {
                    const twd = parseFloat(twdInput.value);
                    audInput.value = isNaN(twd) ? '' : (twd / rate).toFixed(2);
                }
            };

            audInput.addEventListener('input', () => calculate('aud'));
            twdInput.addEventListener('input', () => calculate('twd'));
            rateInput.addEventListener('input', () => {
                if (audInput.value) calculate('aud');
                updateExpenseTotal();
            });

            // Expense Tracker
            const form = document.getElementById('expense-form');
            form.addEventListener('submit', (e) => {
                e.preventDefault();
                const name = document.getElementById('expense-name').value;
                const amount = parseFloat(document.getElementById('expense-amount').value);
                
                if (name && !isNaN(amount)) {
                    expenses.push({ id: Date.now(), name, amount });
                    document.getElementById('expense-name').value = '';
                    document.getElementById('expense-amount').value = '';
                    renderExpenses();
                }
            });
        }

        function renderExpenses() {
            const list = document.getElementById('expense-list');
            if (expenses.length === 0) {
                list.innerHTML = '<li class="text-center text-slate-400 py-6 text-sm font-medium">尚無紀錄，開始新增吧！</li>';
                updateExpenseTotal();
                return;
            }

            list.innerHTML = '';
            expenses.forEach(exp => {
                list.innerHTML += `
                    <li class="flex justify-between items-center p-3 bg-white rounded-lg border border-slate-200 shadow-sm">
                        <span class="font-bold text-slate-700">${exp.name}</span>
                        <div class="flex items-center gap-3">
                            <span class="font-black text-slate-800">$${exp.amount.toFixed(2)}</span>
                            <button onclick="deleteExpense(${exp.id})" class="text-red-400 hover:text-red-600 focus:outline-none transition">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </button>
                        </div>
                    </li>
                `;
            });
            
            const container = list.parentElement;
            container.scrollTop = container.scrollHeight;
            updateExpenseTotal();
        }

        function deleteExpense(id) {
            expenses = expenses.filter(e => e.id !== id);
            renderExpenses();
        }

        function updateExpenseTotal() {
            const totalAud = expenses.reduce((sum, exp) => sum + exp.amount, 0);
            const rate = parseFloat(document.getElementById('custom-rate').value) || 21.5;
            const totalTwd = Math.round(totalAud * rate);

            document.getElementById('total-aud').textContent = `$${totalAud.toFixed(2)}`;
            document.getElementById('total-twd').textContent = `NT$${totalTwd.toLocaleString()}`;
        }

